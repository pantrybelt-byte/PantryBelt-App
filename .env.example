# PantryBelt — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit the real .env file to version control.

# Firebase Web API Key (from Firebase Console → Project Settings → General)
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here

# Google Gemini API Key (from https://aistudio.google.com/app/apikey)
EXPO_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# Google Maps API Key for iOS/Android map rendering (from Google Cloud Console)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Google Maps Geocoding API Key for seedPantries.js script (can be same key as above)
GOOGLE_MAPS_GEOCODING_KEY=your_google_maps_geocoding_key_here
