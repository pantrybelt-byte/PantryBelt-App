{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "config/**/*.ts",
    "context/**/*.ts",
    "context/**/*.tsx",
    "*.ts"
  ],
  "exclude": [
    "node_modules",
    "Pantry-Belt-Landing-Page-",
    ".expo",
    "dist",
    "web-build"
  ]
}
